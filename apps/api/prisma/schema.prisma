generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum UserGoal {
  MUSCLE_GAIN
  FAT_LOSS
  STRENGTH
}

enum ExerciseType {
  COMPOUND
  ISOLATION
}

enum MuscleGroup {
  CHEST
  BACK
  LEGS
  SHOULDERS
  ARMS
  CORE
  GLUTES
  FULL_BODY
}

enum MuscleSkill {
  CHEST
  BACK
  LATS
  LEGS
  ARMS
  CORE
}

enum AchievementCode {
  VOLUME_SESSION_1000
  LIFETIME_VOLUME_5000000
  DAWN_WARRIOR
  STREAK_30_DAYS
  PR_STREAK_3_IN_3_WEEKS
  CLUB_100
  OPEN_APP_7_DAYS_NO_WORKOUT
  REST_MONSTER
}

enum GamificationNotificationType {
  ACHIEVEMENT_UNLOCKED
  MUSCLE_LEVEL_UP
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  passwordHash   String
  name           String
  level          UserLevel           @default(BEGINNER)
  goal           UserGoal            @default(MUSCLE_GAIN)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  workoutSessions WorkoutSession[]
  personalRecords PersonalRecord[]
  bodyMetrics     BodyMetric[]
  trainingPlans   TrainingPlan[]
  weeklyStats     WeeklyWorkoutStat[]
  customExercises CustomExercise[]
  muscleSkillProgresses MuscleSkillProgress[]
  muscleExpLedgers      MuscleExpLedger[]
  achievements          UserAchievement[]
  gamificationNotifications GamificationNotification[]
  dailyAppOpens         UserDailyAppOpen[]
  exerciseStats         UserExerciseStat[]
  personalRecordEvents  PersonalRecordEvent[]
  gamificationStat      UserGamificationStat?
  gamificationJobRuns   GamificationJobRun[]
}

model WorkoutSession {
  id          String        @id @default(cuid())
  userId      String
  sessionDate DateTime      @db.Date
  timezoneOffsetMinutes Int?
  startedAt   DateTime
  endedAt     DateTime?
  notes       String?
  totalVolume Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries     WorkoutEntry[]
  muscleExpLedgers MuscleExpLedger[]
  personalRecordEvents PersonalRecordEvent[]
  gamificationJobRuns   GamificationJobRun[]

  @@index([userId, sessionDate])
  @@index([userId, sessionDate, createdAt])
  @@index([userId, sessionDate(sort: Desc)], map: "WorkoutSession_userId_sessionDate_desc_idx")
}

model WorkoutEntry {
  id          String         @id @default(cuid())
  sessionId   String
  exerciseName String
  sets        Int
  reps        Int
  weightKg    Float?
  rpe         Float?
  isCompleted Boolean        @default(true)
  durationSec Int?
  restSeconds Int?
  volume      Float          @default(0)
  estimated1Rm Float         @default(0)
  createdAt   DateTime       @default(now())
  session     WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, exerciseName])
  @@index([sessionId, createdAt])
  @@index([exerciseName, createdAt])
  @@index([exerciseName, sessionId])
  @@index([weightKg])
}

model UserExerciseStat {
  id            String   @id @default(cuid())
  userId        String
  exerciseName  String
  entryCount    Int      @default(0)
  firstWeightKg Float    @default(0)
  latestWeightKg Float   @default(0)
  bestWeightKg  Float    @default(0)
  firstLiftAt   DateTime?
  latestLiftAt  DateTime?
  bestLiftAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseName])
  @@index([userId, updatedAt])
}

model PersonalRecord {
  id           String   @id @default(cuid())
  userId       String
  exerciseName String
  bestWeightKg Float    @default(0)
  bestVolume   Float    @default(0)
  achievedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseName])
  @@index([userId, bestWeightKg, bestVolume])
  @@index([userId, updatedAt])
}

model BodyMetric {
  id           String   @id @default(cuid())
  userId       String
  loggedAt     DateTime @db.Date
  weightKg     Float
  bodyFatPct   Float?
  muscleMassKg Float?
  notes        String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
}

model TrainingPlan {
  id         String            @id @default(cuid())
  userId     String
  name       String
  goal       UserGoal
  level      UserLevel
  isTemplate Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  days       TrainingPlanDay[]
}

model TrainingPlanDay {
  id        String       @id @default(cuid())
  planId    String
  dayOfWeek Int
  focus     String
  exercises Json         @db.JsonB
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  plan      TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, dayOfWeek])
}

model WeeklyWorkoutStat {
  id              String   @id @default(cuid())
  userId          String
  isoWeek         String
  totalVolume     Float    @default(0)
  sessionsCount   Int      @default(0)
  strongestLiftKg Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, isoWeek])
  @@index([userId, isoWeek])
}

model CustomExercise {
  id               String       @id @default(cuid())
  userId           String
  name             String
  muscleGroup      MuscleGroup
  exerciseType     ExerciseType
  defaultRestSeconds Int       @default(90)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, muscleGroup])
}

model MuscleSkillProgress {
  id        String      @id @default(cuid())
  userId    String
  skill     MuscleSkill
  totalExp  Float       @default(0)
  level     Int         @default(1)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([userId, skill])
}

model MuscleExpLedger {
  id               String      @id @default(cuid())
  userId           String
  sessionId        String
  skill            MuscleSkill
  isoWeek          String
  baseExp          Float
  rpeMultiplier    Float       @default(1)
  streakMultiplier Float       @default(1)
  awardedExp       Float
  createdAt        DateTime    @default(now())
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session          WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, skill])
  @@index([userId, skill, isoWeek])
  @@index([userId, createdAt])
}

model UserAchievement {
  id            String          @id @default(cuid())
  userId        String
  code          AchievementCode
  progressValue Float           @default(0)
  targetValue   Float           @default(1)
  isUnlocked    Boolean         @default(false)
  unlockedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, code])
  @@index([userId, isUnlocked])
}

model GamificationNotification {
  id        String                       @id @default(cuid())
  userId    String
  type      GamificationNotificationType
  title     String
  message   String
  payload   Json?                        @db.JsonB
  createdAt DateTime                     @default(now())
  readAt    DateTime?
  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model UserDailyAppOpen {
  id           String   @id @default(cuid())
  userId       String
  activityDate DateTime @db.Date
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, activityDate])
  @@index([userId, activityDate])
}

model PersonalRecordEvent {
  id           String        @id @default(cuid())
  userId       String
  sessionId    String
  exerciseName String
  bestWeightKg Float         @default(0)
  bestVolume   Float         @default(0)
  achievedAt   DateTime      @default(now())
  isoWeek      String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session      WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, achievedAt])
  @@index([userId, exerciseName, achievedAt])
  @@index([userId, isoWeek])
}

model UserGamificationStat {
  id               String   @id @default(cuid())
  userId           String   @unique
  totalVolumeLifted Float   @default(0)
  maxSessionVolume Float    @default(0)
  maxWeightKg      Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model GamificationJobRun {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  jobKey    String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sessionId, createdAt])
}
