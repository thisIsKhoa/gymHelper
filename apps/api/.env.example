PORT=4000
NODE_ENV=development
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=gymhelper:
JWT_SECRET=replace_with_a_long_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
# Supabase Session Pooler (IPv4 compatible)
# Add connection_limit/pool_timeout to prevent MaxClientsInSessionMode under load
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[DB-REGION].pooler.supabase.com:5432/postgres?connection_limit=1&pool_timeout=20
