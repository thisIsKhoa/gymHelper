PORT=4000
NODE_ENV=development
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=40
WORKOUT_RATE_LIMIT_MAX=120
HTTP_SLOW_REQUEST_MS=1000
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=gymhelper:
JWT_SECRET=replace_with_a_long_secret
JWT_EXPIRES_IN=7d
# If web and API are on different top-level domains in production, enable cross-site cookie mode.
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SECURE=true
CORS_ORIGIN=http://localhost:5173
ADMIN_EMAILS=admin@example.com
# Supabase Session Pooler (IPv4 compatible)
# Add connection_limit/pool_timeout to prevent MaxClientsInSessionMode under load
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[DB-REGION].pooler.supabase.com:5432/postgres?connection_limit=1&pool_timeout=20
