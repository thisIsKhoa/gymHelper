# API
PORT=4000
NODE_ENV=development
JWT_SECRET=replace_with_a_long_secret
JWT_EXPIRES_IN=7d
# If web and API are on different top-level domains in production, enable cross-site cookie mode.
# AUTH_COOKIE_SAME_SITE=none
# AUTH_COOKIE_SECURE=true
CORS_ORIGIN=http://localhost:5173
# Supabase Session Pooler (IPv4 compatible)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[DB-REGION].pooler.supabase.com:5432/postgres
